{
  "name": "sof-logger",
  "displayName": "SOF Logger",
  "description": "Visualizes QEMU Logs with PS bits and Cache Misses",
  "version": "0.0.1",
  "publisher": "thesofproject",
  "repository": {
    "type": "git",
    "url": "https://github.com/thesofproject/sof"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sof-logger.visualize",
        "title": "SOF Logger: Visualize QEMU Log"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0"
  }
}
