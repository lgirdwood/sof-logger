{
  "name": "sof-logger",
  "displayName": "SOF Logger",
  "description": "Visualizes QEMU Logs with PS bits and Cache Misses",
  "version": "0.0.1",
  "publisher": "thesofproject",
  "repository": {
    "type": "git",
    "url": "https://github.com/thesofproject/sof"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sof-logger.visualize",
        "title": "SOF Logger: Visualize QEMU Log"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sof-logger",
          "title": "SOF Logger",
          "icon": "$(pulse)"
        }
      ]
    },
    "views": {
      "sof-logger": [
        {
          "type": "webview",
          "id": "sofSearchView",
          "name": "SOF Qemu"
        },
        {
          "id": "sofTraceView",
          "name": "SOF Execution Trace"
        },
        {
          "id": "sofMemoryView",
          "name": "SOF Allocations & Symbols"
        }
      ]
    },
    "configuration": {
      "title": "SOF Logger",
      "properties": {
        "sofLogger.qemuPath": {
          "type": "string",
          "default": "qemu-system-xtensa",
          "description": "Path to the QEMU execution binary"
        },
        "sofLogger.targetBuildDir": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the target build directory where zephyr.ri (kernel) and zephyr.elf reside"
        },
        "sofLogger.qemuOptions": {
          "type": "string",
          "default": "",
          "description": "General QEMU execution parameters and memory dimensions"
        },
        "sofLogger.qemuTargetOptions": {
          "type": "string",
          "default": "",
          "description": "Board, Machine, or specific Target options (-machine, -cpu, etc.)"
        },
        "sofLogger.qemuLoggingOptions": {
          "type": "string",
          "default": "",
          "description": "QEMU trace, plugin, or logging specific flags (-d, -trace, etc.)"
        },
        "sofLogger.qemuLogFile": {
          "type": "string",
          "default": "/tmp/qemu-exec-default.log",
          "description": "Absolute path to the QEMU execution trace log."
        },
        "sofLogger.mtraceLogFile": {
          "type": "string",
          "default": "/tmp/ace-mtrace.log",
          "description": "Absolute path to the exported Zephyr terminal string output log."
        },
        "sofLogger.bufferSizeMB": {
          "type": "number",
          "default": 50,
          "description": "Megabyte limit for child_process buffer captures (e.g. `nm -l` execution)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0"
  }
}
